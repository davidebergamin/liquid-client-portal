# Project API URL, not the dashboard URL. Example: https://abcdefghijklmnopqrst.supabase.co
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional local admin fallback. Supabase Auth works with SUPABASE_URL + SUPABASE_PUBLISHABLE_KEY.
LIQUID_ADMIN_PASSWORD=

# Recommended for deploy/public links and future browser-side Supabase usage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Local: http://localhost:3000 | Production: https://liquid-client-portal.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
